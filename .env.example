# Copy to .env or export these before running the backend.
# Free Gemini API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Optional model overrides (both have free tiers):
# CP_TUTOR_ROUTER_MODEL=gemini-2.5-flash-lite
# CP_TUTOR_MAIN_MODEL=gemini-2.5-flash

# Optional: override the sandbox image name (default: cp-tutor-sandbox)
# CP_TUTOR_SANDBOX_IMAGE=cp-tutor-sandbox
